# AgentTeams Controller endpoint (used by server-side proxy)
AGENTTEAMS_CONTROLLER_URL=http://127.0.0.1:8090

# Higress Console endpoint (for shared authentication with Higress).
# When set, login is proxied to Higress Console; otherwise a local user store is used.
# AGENTTEAMS_AI_GATEWAY_ADMIN_URL=http://127.0.0.1:8001

# Optional: browser-facing controller URL default (can be overridden in UI)
NEXT_PUBLIC_AGENTTEAMS_CONTROLLER_URL=http://127.0.0.1:8090

# Authentication to AgentTeams Controller.
# Prefer AGENTTEAMS_AUTH_TOKEN_FILE for rotated ServiceAccount tokens.
# AGENTTEAMS_AUTH_TOKEN=
AGENTTEAMS_AUTH_TOKEN_FILE=/var/run/agentteams/cli-token

# Matrix homeserver URL default (can be overridden in UI)
NEXT_PUBLIC_MATRIX_API_URL=http://matrix-local.agentteams.io:18080

# Matrix homeserver whitelist for the proxy (comma-separated hostnames)
MATRIX_HOMESERVER_ALLOWLIST=matrix-local.agentteams.io,matrix.org,example.com

# Base path when embedded as a sub-application in AgentTeams.
# Leave empty for standalone root deployment.
NEXT_PUBLIC_BASE_PATH=/dashboard

# Optional: force deployment mode for menu filtering.
# When unset, mode is auto-detected from Controller API or K8s serviceaccount.
# AGENTTEAMS_DEPLOYMENT_MODE=embedded

# MinIO Object Storage (used by Storage section in embedded mode)
# AGENTTEAMS_FS_ENDPOINT=http://agentteams-minio.agentteams-system:9000
# AGENTTEAMS_FS_ACCESS_KEY=minioadmin
# AGENTTEAMS_FS_SECRET_KEY=minioadmin
# AGENTTEAMS_FS_BUCKET=agentteams-data
# AGENTTEAMS_FS_REGION=us-east-1

# LLM API Key for AI Troubleshooting (optional)
# AGENTTEAMS_LLM_API_KEY=sk-...
# AGENTTEAMS_DEFAULT_MODEL=gpt-4
